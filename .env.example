# ════════════════════════════════════════════════════════════════════
# GAP50001 — Environment Variables Template (copy to .env, never commit .env!)
# ════════════════════════════════════════════════════════════════════
# Copy this file: cp .env.example .env
# Then fill in ALL required values below

# ── Database (PostgreSQL) ────────────────────────────────────────────
POSTGRES_USER=admin
POSTGRES_PASSWORD=CHANGE_THIS_STRONG_PASSWORD
POSTGRES_DB=iso50001gap

# ── JWT Security ─────────────────────────────────────────────────────
# Generate with: openssl rand -base64 64
JWT_SECRET=CHANGE_THIS_TO_RANDOM_64_CHAR_SECRET

# ── Admin Seed (only used on first boot if no users exist) ───────────
SEED_ADMIN_USER=your_admin_username
SEED_ADMIN_PASS=YourStr0ng!PassW0rd#Here
SEED_ADMIN_EMAIL=admin@yourcompany.com

# ── CORS Origins (comma-separated) ──────────────────────────────────
CORS_ORIGIN=https://103.81.84.233:8888,http://localhost:8888

# ── Optional: JWT expiry ─────────────────────────────────────────────
# JWT_EXPIRES=24h
